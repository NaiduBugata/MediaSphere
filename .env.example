# ---- Groq API (analyzer) ----
# At least one key is required. Add more for higher throughput.
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.0
GROQ_TIMEOUT_SECONDS=120
WORKERS=5
MAX_RETRIES=5
COOLDOWN_SECONDS=60
EMPTY_ARTICLE_MIN_CHARS=25

# ---- Analyzer I/O ----
INPUT_FILE=article.txt
OUTPUT_DIR=output
CHECKPOINT_FILE=checkpoint.json

# ---- MongoDB Atlas (MediaSphere) ----
# URL-encode special characters in the password (e.g. '@' -> '%40').
MONGODB_URI=
MONGODB_DB_NAME=MediaSphere
MONGODB_COLLECTION=articles

# ---- API server (production) ----
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
