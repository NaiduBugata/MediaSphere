# ---- Groq API (analyzer) ----
# Any numbered keys work: GROQ_API_KEY_1, GROQ_API_KEY_5, etc. (at least one required).
# GROQ_API_KEY and GROQ_API_KEYS are also supported by legacy/report tooling.
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.0
GROQ_TIMEOUT_SECONDS=120
WORKERS=5
MAX_RETRIES=5
COOLDOWN_SECONDS=60
EMPTY_ARTICLE_MIN_CHARS=25

# ---- Analyzer I/O ----
INPUT_FILE=article.txt
OUTPUT_DIR=output
CHECKPOINT_FILE=checkpoint.json

# ---- Pipeline scheduler (Lokal + YouTube) ----
# Hours between combined collection cycles (default: 1).
PIPELINE_INTERVAL_HOURS=1
# Run the pipeline INSIDE the web service (needed on hosts without background
# workers, e.g. Render free tier). Requires gunicorn --workers 1.
PIPELINE_ON_API=false
# Run one pipeline cycle shortly after startup (collect anything missed while down).
PIPELINE_CATCHUP_ON_START=true

# ---- MongoDB Atlas (MediaSphere) ----
# URL-encode special characters in the password (e.g. '@' -> '%40').
MONGODB_URI=
MONGODB_DB_NAME=MediaSphere
MONGODB_COLLECTION=articles

# ---- API server (production) ----
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://media-sphere-omega.vercel.app

# ---- Daily Constituency Intelligence Report ----
REPORT_ENABLED=true
# Keep false on the API web service; enable on a dedicated worker if needed.
REPORT_SCHEDULER_ON_API=false
REPORT_CATCHUP_ON_START=false
# Disable all email until configured. Set true once SMTP (local) or Resend (Render) is ready.
EMAIL_ENABLED=false
# smtp = Gmail (local/VPS) | resend = HTTPS API (Render free tier) | auto = Resend if RESEND_API_KEY set
EMAIL_PROVIDER=auto
REPORT_TIMEZONE=Asia/Kolkata
REPORT_HOUR=7
REPORT_MINUTE=0
REPORT_CONSTITUENCY=Narasaraopet
REPORT_OUTPUT_DIR=reports_output

# ---- SMTP email delivery ----
# For Gmail, create an App Password (Account > Security > App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=MediaSphere Intelligence
SMTP_FROM_EMAIL=
SMTP_MAX_RETRIES=3
SMTP_RETRY_BACKOFF_SECONDS=5

# Comma-separated recipient list (MP, PA, constituency office, admins).
REPORT_RECIPIENTS=

# ---- YouTube pipeline (separate API key from Lokal) ----
YOUTUBE_ENABLED=true
YOUTUBE_API_KEY=
YOUTUBE_SEARCH_PERIOD_DAYS=2
YOUTUBE_MAX_RESULTS_PER_KEYWORD=50
YOUTUBE_CHECK_INTERVAL=3600
YOUTUBE_MAX_NEW_PER_RUN=30
YOUTUBE_MAX_CONTENT_CHARS=6000
YOUTUBE_MIN_CONTENT_CHARS=100

# ---- Resend (recommended for Render — HTTPS, not blocked like SMTP) ----
# Sign up at https://resend.com → API Keys → create key → paste below.
# Free tier: use onboarding@resend.dev as FROM until you verify your domain.
RESEND_API_KEY=

# ---- WhatsApp Cloud API ----
# Meta webhook verification token (must match Meta Developer Console).
WHATSAPP_VERIFY_TOKEN=
# Permanent access token from Meta App → WhatsApp → API Setup.
WHATSAPP_ACCESS_TOKEN=
# Phone number ID from Meta App → WhatsApp → API Setup.
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp Business Account ID (WABA).
WHATSAPP_WABA_ID=
# Graph API version (default v25.0).
WHATSAPP_GRAPH_API_VERSION=v25.0
# Enable GET/POST /webhook routes (default true).
WHATSAPP_WEBHOOK_ENABLED=true
